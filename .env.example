DATABASE_URL=postgresql://scheduler:scheduler_password@localhost:5435/scheduler_db

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_at_least_64_chars_long
JWT_REFRESH_SECRET=another_very_long_random_string_for_refresh_tokens

# ─── API Server ───────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ─── Worker ───────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_DEAD_THRESHOLD_MS=30000

# ─── AI Summaries (Bonus Feature) ────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ─── Cron Scheduler ───────────────────────────────────────────────
CRON_POLL_INTERVAL_MS=60000
CRON_LOCK_TTL_MS=30000
